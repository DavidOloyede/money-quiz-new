# Money Quiz API server configuration. Copy to server/.env and fill in.
# With nothing set the server won't boot (DATABASE_URL is required); with
# Plaid unset it runs in mock mode.

# ---------------------------------------------------------------------------
# Database — any PostgreSQL. Supabase: Settings → Database → Connection string
# (use the pooled "Transaction" connection string for serverless/most hosts).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ---------------------------------------------------------------------------
# Supabase Auth — only used to VERIFY login tokens (login still happens in the
# browser via supabase-js). From Settings → API.
# ---------------------------------------------------------------------------
SUPABASE_URL=
# Legacy HS256 secret (Settings → API → JWT Secret). Leave blank if your
# project uses asymmetric signing keys — we verify via the JWKS endpoint then.
SUPABASE_JWT_SECRET=

# The seed admin account (granted role=admin on first sign-in).
ADMIN_EMAIL=davidoloyede00@gmail.com

# ---------------------------------------------------------------------------
# Plaid (optional). Unset ⇒ mock mode with realistic fake transactions.
# From dashboard.plaid.com → Team settings → Keys.
# ---------------------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# 32-byte base64 key for encrypting Plaid access tokens at rest:
#   openssl rand -base64 32
PLAID_TOKEN_KEY=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8787
# Comma-separated allowlist for CORS (only for split-origin deploys; in dev the
# Vite proxy makes requests same-origin, so this can stay blank).
CORS_ORIGINS=
# Set true in production to serve the built frontend (dist/) from this server.
SERVE_STATIC=false
SENTRY_DSN=
