# Money Quiz — FRONTEND build-time config. Copy to ".env" and fill in.
# Optional: with nothing set the app runs fully local (localStorage only).
# The Node API server has its own config — see server/.env.example.

# ---------------------------------------------------------------------------
# Supabase — used ONLY for login (accounts, Google OAuth, password resets).
# From your project's dashboard: Settings → API.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry browser error tracking (optional). sentry.io → project → Client Keys.
VITE_SENTRY_DSN=

# Where the app calls the Node API. Defaults to same-origin "/api" (the Vite
# dev server proxies it to the API). Only set this for split-origin deploys,
# e.g. https://api.moneyquiz.app/api
# VITE_API_URL=/api
