{
  "name": "money-quiz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "tsc -b",
    "server": "npm --prefix server run dev",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm run dev\" \"npm run server\"",
    "db:generate": "npm --prefix server run db:generate",
    "db:migrate": "npm --prefix server run db:migrate",
    "db:studio": "npm --prefix server run db:studio"
  },
  "dependencies": {
    "@sentry/react": "^10.57.0",
    "@supabase/supabase-js": "^2.108.1",
    "papaparse": "^5.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.8"
  }
}
