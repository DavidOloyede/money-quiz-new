# Money Quiz — backend configuration. Copy to ".env" and fill in.
# Everything is optional: with nothing set, the app runs fully local
# (localStorage only, mock bank mode) exactly as before.

# ---------------------------------------------------------------------------
# Supabase (accounts, cloud sync, support tickets, admin panel).
# From your project's dashboard: Settings → API.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry error tracking (optional). From sentry.io: project → Client Keys (DSN).
VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Plaid — LOCAL DEV SERVER ONLY (npm run server). In production these live in
# Supabase Edge Function secrets instead:
#   npx supabase secrets set PLAID_CLIENT_ID=... PLAID_SECRET=... \
#     PLAID_ENV=sandbox PLAID_TOKEN_KEY=$(openssl rand -base64 32)
# With these unset, the local server runs in MOCK mode (fake data, no Plaid
# account needed) so you can try the full connect → import flow.
# ---------------------------------------------------------------------------

# From the Plaid dashboard (https://dashboard.plaid.com):
PLAID_CLIENT_ID=
PLAID_SECRET=

# sandbox | production  (use the matching secret for the environment)
PLAID_ENV=sandbox

# Comma-separated. transactions is all this app needs.
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# Port the local backend listens on (the frontend defaults to this).
PORT=8787

# Optional: override the API base the frontend calls (Vite env, build-time).
# VITE_PLAID_API=http://localhost:8787
