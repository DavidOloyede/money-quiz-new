# Money Quiz — optional Plaid backend configuration.
# Copy to ".env" and fill in to enable real bank connections.
# With these unset, the server runs in MOCK mode (fake data, no Plaid account
# needed) so you can try the full connect → import flow.

# From the Plaid dashboard (https://dashboard.plaid.com):
PLAID_CLIENT_ID=
PLAID_SECRET=

# sandbox | production  (use the matching secret for the environment)
PLAID_ENV=sandbox

# Comma-separated. transactions is all this app needs.
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# Port the local backend listens on (the frontend defaults to this).
PORT=8787

# Optional: override the API base the frontend calls (Vite env, build-time).
# VITE_PLAID_API=http://localhost:8787
